{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "typecheck"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck", "sanity:typegen"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true
    },
    "sanity:typegen": {
      "inputs": [
        "src/sanity/**/*.{ts,tsx}",
        "src/app/**/*.{ts,tsx}",
        "src/ui/**/*.{ts,tsx}",
        "sanity.cli.ts",
        "sanity.config.ts"
      ],
      "outputs": [
        "src/sanity/schema.json",
        "src/sanity/types.ts"
      ]
    },
    "tauri:dev": {
      "cache": false,
      "persistent": true
    },
    "tauri:build": {
      "dependsOn": ["typecheck"],
      "cache": false
    }
  }
}
